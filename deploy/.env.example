# Leave Tracker — runtime environment variables
# Copy to .env next to server.js (or use your platform's env-var UI) and edit.

# TCP port the server binds to
PORT=5000

# Bind address. Use 0.0.0.0 inside Docker / behind a reverse proxy.
HOST=0.0.0.0

# Set to "production" in deployed environments — enables cache headers on
# the static React bundle and silences dev-only error detail.
NODE_ENV=production
